ib= 55.18 | макс.press=176.83\n","  Скважина 36: записей=1479 | ср.vib= 55.57 | макс.press=180.75\n","  Скважина 37: записей=1532 | ср.vib= 55.89 | макс.press=181.16\n","  Скважина 38: записей=1519 | ср.vib= 54.21 | макс.press=179.57\n","  Скважина 39: записей=1558 | ср.vib= 55.64 | макс.press=181.86\n","  Скважина 40: записей=1595 | ср.vib= 55.53 | макс.press=181.05\n","  Скважина 41: записей=1532 | ср.vib= 55.15 | макс.press=175.79\n","  Скважина 42: записей=1561 | ср.vib= 53.89 | макс.press=180.95\n","  Скважина 43: записей=1450 | ср.vib= 57.25 | макс.press=182.19\n","  Скважина 44: записей=1522 | ср.vib= 56.41 | макс.press=182.62\n","  Скважина 45: записей=1491 | ср.vib= 56.34 | макс.press=179.09\n","  Скважина 46: записей=1467 | ср.vib= 55.65 | макс.press=182.68\n","  Скважина 47: записей=1537 | ср.vib= 56.28 | макс.press=180.94\n","  Скважина 48: записей=1514 | ср.vib= 52.61 | макс.press=179.17\n","  Скважина 49: записей=1533 | ср.vib= 58.09 | макс.press=182.36\n","  Скважина 50: записей=1492 | ср.vib= 58.51 | макс.press=182.25\n","  Скважина 51: записей=1523 | ср.vib= 56.00 | макс.press=182.28\n","  Скважина 52: записей=1489 | ср.vib= 55.42 | макс.press=181.78\n","  Скважина 53: записей=1489 | ср.vib= 54.33 | макс.press=182.66\n","  Скважина 54: записей=1559 | ср.vib= 55.09 | макс.press=180.18\n","  Скважина 55: записей=1572 | ср.vib= 56.41 | макс.press=181.70\n","  Скважина 56: записей=1573 | ср.vib= 53.88 | макс.press=172.62\n","  Скважина 57: записей=1564 | ср.vib= 52.95 | макс.press=182.67\n","  Скважина 58: записей=1510 | ср.vib= 54.92 | макс.press=181.61\n","  Скважина 59: записей=1527 | ср.vib= 54.21 | макс.press=181.12\n","  Скважина 60: записей=1484 | ср.vib= 55.65 | макс.press=180.05\n","  Скважина 61: записей=1490 | ср.vib= 55.83 | макс.press=182.57\n","  Скважина 62: записей=1545 | ср.vib= 54.03 | макс.press=181.66\n","  Скважина 63: записей=1500 | ср.vib= 55.90 | макс.press=182.45\n","  Скважина 64: записей=1474 | ср.vib= 55.99 | макс.press=182.51\n","  Скважина 65: записей=1431 | ср.vib= 60.49 | макс.press=178.27\n","  Скважина 66: записей=1474 | ср.vib= 54.07 | макс.press=182.22\n","  Скважина 67: записей=1549 | ср.vib= 56.12 | макс.press=182.85\n","  Скважина 68: записей=1509 | ср.vib= 53.69 | макс.press=182.11\n","  Скважина 69: записей=1477 | ср.vib= 55.11 | макс.press=182.46\n","  Скважина 70: записей=1539 | ср.vib= 54.99 | макс.press=177.26\n","  Скважина 71: записей=1484 | ср.vib= 54.30 | макс.press=181.70\n","  Скважина 72: записей=1541 | ср.vib= 53.88 | макс.press=181.34\n","  Скважина 73: записей=1449 | ср.vib= 55.69 | макс.press=180.95\n","  Скважина 74: записей=1472 | ср.vib= 55.36 | макс.press=182.55\n","  Скважина 75: записей=1507 | ср.vib= 57.73 | макс.press=181.83\n","  Скважина 76: записей=1617 | ср.vib= 55.94 | макс.press=182.24\n","  Скважина 77: записей=1548 | ср.vib= 56.61 | макс.press=181.21\n","  Скважина 78: записей=1472 | ср.vib= 54.64 | макс.press=178.29\n","  Скважина 79: записей=1504 | ср.vib= 54.38 | макс.press=177.96\n","  Скважина 80: записей=1588 | ср.vib= 54.93 | макс.press=179.68\n","  Скважина 81: записей=1501 | ср.vib= 55.81 | макс.press=179.77\n","  Скважина 82: записей=1522 | ср.vib= 56.60 | макс.press=177.31\n","  Скважина 83: записей=1481 | ср.vib= 53.95 | макс.press=182.56\n","  Скважина 84: записей=1524 | ср.vib= 54.53 | макс.press=182.41\n","  Скважина 85: записей=1448 | ср.vib= 55.79 | макс.press=178.11\n","  Скважина 86: записей=1495 | ср.vib= 54.82 | макс.press=178.01\n","  Скважина 87: записей=1495 | ср.vib= 53.27 | макс.press=182.07\n","  Скважина 88: записей=1501 | ср.vib= 55.12 | макс.press=182.54\n","  Скважина 89: записей=1460 | ср.vib= 53.35 | макс.press=179.97\n","  Скважина 90: записей=1520 | ср.vib= 56.73 | макс.press=174.16\n","  Скважина 91: записей=1473 | ср.vib= 51.80 | макс.press=181.94\n","  Скважина 92: записей=1538 | ср.vib= 54.66 | макс.press=181.96\n","  Скважина 93: записей=1567 | ср.vib= 53.41 | макс.press=182.09\n","  Скважина 94: записей=1517 | ср.vib= 54.89 | макс.press=181.63\n","  Скважина 95: записей=1446 | ср.vib= 58.23 | макс.press=178.89\n","  Скважина 96: записей=1582 | ср.vib= 56.86 | макс.press=178.33\n","  Скважина 97: записей=1520 | ср.vib= 54.70 | макс.press=181.99\n","  Скважина 98: записей=1420 | ср.vib= 57.12 | макс.press=176.91\n","  Скважина 99: записей=1531 | ср.vib= 54.61 | макс.press=179.77\n","\n"," Нормализация завершена. Проверка: mean(vib_norm) ≈ nan, std(vib_norm) ≈ nan\n","\n"," Нормализация завершена. Проверка: mean(vib_norm) ≈ -0.0000, std(vib_norm) ≈ 1.0000\n"]}]},{"cell_type":"code","source":["# 4.Скользящее окно и разница\n","k = 35  # Размер окна из задания\n","\n","# Добавляем новые поля в структуру данных\n","dt_stage4 = np.dtype(data_norm.dtype.descr + [\n","    ('moving_avg_vib', 'float32'),  # Скользящее среднее вибрации\n","    ('press_diff', 'float32'),      # Скорость изменения давления\n","    ('press_abs_diff', 'float32')   # Новый признак: Сила перепада давления\n","])\n","\n","data_stage4 = np.zeros(len(data_norm), dtype=dt_stage4)\n","\n","# Копируем все старые данные в новый массив (быстрая операция)\n","for name in data_norm.dtype.names:\n","    data_stage4[name] = data_norm[name]\n","\n","# 2. Скользящее среднее СКОЛЬЗЯЩЕЕ СРЕДНЕЕ\n","vib = data_stage4['vib']\n","\n","# Кумулятивные суммы и счетчики\n","c_sum = np.nancumsum(vib)\n","c_cnt = np.nancumsum(~np.isnan(vib))\n","\n","# Добавляем 0 в начало, чтобы индексы сдвинулись корректно\n","c_sum = np.concatenate(([0.0], c_sum))\n","c_cnt = np.concatenate(([0], c_cnt))\n","\n","# Формула скользящего окна: (Сумма до конца) - (Сумма до начала окна)\n","sum_window = c_sum[k:] - c_sum[:-k]\n","cnt_window = c_cnt[k:] - c_cnt[:-k]\n","\n","# Безопасное деление: если в окне нет валидных данных (0), то результат NaN\n","moving_avg = np.where(cnt_window > 0, sum_window / cnt_window, np.nan)\n","\n","# Обрезаем первые k-1 значений (заполняем NaN, так как окно ещё не сформировано)\n","data_stage4['moving_avg_vib'] = np.concatenate([\n","    np.full(k-1, np.nan, dtype='float32'),\n","    moving_avg\n","])\n","\n","print(f\" Скользящее среднее (vib, k={k}) рассчитано.\")\n","#  Вывод первых валидных значений\n","first_valid = data_stage4['moving_avg_vib'][k-1:k+4]\n","print(f\"   Первые 5 значений скользящего среднего: {first_valid}\")\n","\n","# 3. Перепады давления\n","press = data_stage4['press']\n","\n","# Вычисляем разницу между соседними записями\n","press_diff_raw = np.diff(press)\n","\n","# Добавляем 0 в начало, чтобы длина массива осталась прежней\n","data_stage4['press_diff'] = np.concatenate(([0.0], press_diff_raw))\n","\n","print(f\" Перепады давления (press_diff) рассчитаны.\")\n","#  Статистика перепадов\n","p_diff = data_stage4['press_diff']\n","print(f\"   press_diff: min={np.nanmin(p_diff):.2f} | max={np.nanmax(p_diff):.2f} | mean={np.nanmean(p_diff):.4f} атм\")\n","\n","# 4. Новый признак\n","data_stage4['press_abs_diff'] = np.abs(data_stage4['press_diff'])\n","\n","print(f\" Создан новый признак: press_abs_diff (абсолютное значение перепада).\")\n","#  Статистика абсолютных перепадов\n","p_abs = data_stage4['press_abs_diff']\n","print(f\"   press_abs_diff: min={np.nanmin(p_abs):.2f} | max={np.nanmax(p_abs):.2f} | mean={np.nanmean(p_abs):.4f} атм\")\n","\n","np.save('/content/data_stage4.npy', data_stage4)\n","print(\" Массив сохранён в data_stage4.npy\")\n","\n","#  Наглядная проверка: выводим 5 строк, где уже есть все значения\n","print(\"\\n Пример данных (индексы 35-39):\")\n","print(f\"{'idx':<5} | {'vib':<7} | {'ma_vib':<7} | {'press':<7} | {'diff':<7} | {'abs_diff':<7}\")\n","print(\"-\" * 50)\n","for i in range(k, k+5):\n","    print(f\"{i:<5} | {data_stage4['vib'][i]:<7.2f} | {data_stage4['moving_avg_vib'][i]:<7.2f} | \"\n","          f\"{data_stage4['press'][i]:<7.2f} | {data_stage4['press_diff'][i]:<7.2f} | \"\n","          f\"{data_stage4['press_abs_diff'][i]:<7.2f}\")"],"metadata":{"colab":{"base_uri":"https://localhost:8080/"},"collapsed":true,"id":"OR6ZQOGuPYIJ","outputId":"81a4103a-59f5-4bfb-8351-b86a0ce918e9"},"execution_count":null,"outputs":[{"output_type":"stream","name":"stdout","text":[" Скользящее среднее (vib, k=35) рассчитано.\n","   Первые 5 значений скользящего среднего: [41.12531  41.16993  41.275463 40.92959  39.686565]\n"," Перепады давления (press_diff) рассчитаны.\n","   press_diff: min=-222.92 | max=214.93 | mean=-0.0043 атм\n"," Создан новый признак: press_abs_diff (абсолютное значение перепада).\n","   press_abs_diff: min=0.00 | max=222.92 | mean=19.0003 атм\n"," Массив сохранён в data_stage4.npy\n","\n"," Пример данных (индексы 35-39):\n","idx   | vib     | ma_vib  | press   | diff    | abs_diff\n","--------------------------------------------------\n","35    | 51.24   | 41.17   | 4.35    | -16.68  | 16.68  \n","36    | 68.66   | 41.28   | 22.89   | 18.54   | 18.54  \n","37    | 43.89   | 40.93   | 16.28   | -6.61   | 6.61   \n","38    | 6.31    | 39.69   | 25.94   | 9.66    | 9.66   \n","39    | 34.53   | 39.63   | 38.71   | 12.77   | 12.77  \n"]}]},{"cell_type":"code","source":["# 5. Создание производных признаков (Feature Engineering)\n","# 1. Расширяем структуру массива на 2 новых поля\n","dt_stage5 = np.dtype(data_stage4.dtype.descr + [\n","    ('vib_intensity', 'float32'),       # Признак 1 (Нагрузка на оборудование на единицу давления.)\n","    ('temp_press_ratio', 'float32')     # Признак 2 (Термобарический индекс пласта.)\n","])\n","data_stage5 = np.zeros(len(data_stage4), dtype=dt_stage5)\n","\n","# Копируем все предыдущие данные\n","for name in data_stage4.dtype.names:\n","    data_stage5[name] = data_stage4[name]\n","\n","# 2. Безопасные вычисления новых признаков\n","eps = 1e-8  # Защита от деления на ноль\n","\n","# Признак 1\n","data_stage5['vib_intensity'] = data_stage5['vib'] / (data_stage5['press'] + eps)\n","\n","#  Признак 2\n","data_stage5['temp_press_ratio'] = data_stage5['temp'] / (data_stage5['press'] + eps)\n","\n","print(\" Новые признаки рассчитаны.\")\n","\n","# 3. Очистка Inf / -Inf / NaN -> 0\n","for feat in ['vib_intensity', 'temp_press_ratio']:\n","    col = data_stage5[feat]\n","\n","    # 1. Заменяем бесконечности\n","    col = np.where(np.isinf(col), 0.0, col)\n","\n","    # 2. Заменяем NaN\n","    col = np.where(np.isnan(col), 0.0, col)\n","\n","    data_stage5[feat] = col\n","    print(f\"   {feat}: проблемные значения (Inf/NaN) заменены на 0\")\n","\n","np.save('/content/data_stage5.npy', data_stage5)\n","print(\" Массив сохранён в data_stage5.npy\")"],"metadata":{"colab":{"base_uri":"https://localhost:8080/"},"collapsed":true,"id":"rNfr__42qaxE","outputId":"c3885521-96b8-423a-89c5-71f5f7b3bbc3"},"execution_count":null,"outputs":[{"output_type":"stream","name":"stdout","text":[" Новые признаки рассчитаны.\n","   vib_intensity: проблемные значения (Inf/NaN) заменены на 0\n","   temp_press_ratio: проблемные значения (Inf/NaN) заменены на 0\n"," Массив сохранён в data_stage5.npy\n"]}]},{"cell_type":"code","source":["# 6.Условная агрегация по группам\n","# 1. Определяем условие\n","threshold_press = 160.0\n","threshold_vib = 60.0\n","\n","# Составная булева маска\n","mask_critical = (data['press'] > threshold_press) & (data['vib'] > threshold_vib)\n","\n","print(f\" Найдено записей в 'критическом режиме': {np.sum(mask_critical)}\")\n","print(f\" (Давление > {threshold_press} и Вибрация > {threshold_vib})\")\n","\n","# 3. Группировка и рассчет статистики\n","unique_wells = np.unique(data['well_id'])\n","n_groups = len(unique_wells)\n","\n","# Массив для хранения результатов\n","results = np.zeros((n_groups, 3), dtype='float32')\n","\n","print(\"\\n Расчёт статистики вибрации только для критических зон:\")\n","\n","for i, well_id in enumerate(unique_wells):\n","    # Маска текущей группы\n","    mask_group = data['well_id'] == well_id\n","    mask_subset = mask_group & mask_critical\n","\n","    # Проверяем, есть ли вообще такие записи у этой скважины\n","    if np.sum(mask_subset) > 0:\n","        # Извлекаем данные вибрации  для найденных строк\n","        subset_vib = data['vib'][mask_subset]\n","\n","        # Считаем статистику\n","        mean_val = np.nanmean(subset_vib)\n","        median_val = np.nanmedian(subset_vib)\n","        p90_val = np.nanpercentile(subset_vib, 90) # 90-й процентиль (по заданию)\n","\n","        # Сохраняем в таблицу результатов\n","        results[i, 0] = well_id\n","        results[i, 1] = mean_val\n","        results[i, 2] = median_val\n","\n","        # Для отладки покажем первые 5 скважин\n","        if i < 5:\n","             print(f\"  Скважина {int(well_id)}: найдено {np.sum(mask_subset)} крит. точек | \"\n","                   f\"Ср. vib={mean_val:.2f}, Мед. vib={median_val:.2f}, P90={p90_val:.2f}\")\n","    else:\n","        # Если у скважины не было критических режимов\n","        results[i, 0] = well_id\n","        results[i, 1] = np.nan\n","        results[i, 2] = np.nan\n","\n","# 4. ВЫВОД РЕЗУЛЬТАТОВ\n","print(\"\\n\" + \"=\"*60)\n","print(\"ИТОГОВАЯ ТАБЛИЦА (Столбцы: ID, Mean_Cond, Median_Cond)\")\n","print(\"=\"*60)\n","print(results[-10:])\n","\n","# Сохраняем таблицу агрегации\n","np.save('/content/conditional_agg.npy', results)\n","print(f\"\\n Таблица условной агрегации сохранена в conditional_agg.npy\")"],"metadata":{"colab":{"base_uri":"https://localhost:8080/"},"collapsed":true,"id":"XnXwySYjtUxy","outputId":"3ad4fcaa-f7a6-4f9e-9f7f-01ba861e103a"},"execution_count":null,"outputs":[{"output_type":"stream","name":"stdout","text":[" Найдено записей в 'критическом режиме': 4961\n"," (Давление > 160.0 и Вибрация > 60.0)\n","\n"," Расчёт статистики вибрации только для критических зон:\n","  Скважина 0: найдено 49 крит. точек | Ср. vib=95.41, Мед. vib=79.75, P90=110.99\n","  Скважина 1: найдено 45 крит. точек | Ср. vib=103.82, Мед. vib=77.17, P90=185.56\n","  Скважина 2: найдено 42 крит. точек | Ср. vib=98.37, Мед. vib=75.80, P90=109.23\n","  Скважина 3: найдено 43 крит. точек | Ср. vib=90.28, Мед. vib=72.56, P90=102.43\n","  Скважина 4: найдено 52 крит. точек | Ср. vib=106.55, Мед. vib=79.28, P90=224.64\n","\n","============================================================\n","ИТОГОВАЯ ТАБЛИЦА (Столбцы: ID, Mean_Cond, Median_Cond)\n","============================================================\n","[[ 90.       111.68916   78.30787 ]\n"," [ 91.       102.4091    74.32301 ]\n"," [ 92.       126.45537   78.45504 ]\n"," [ 93.        94.711105  75.71457 ]\n"," [ 94.       111.02483   75.18643 ]\n"," [ 95.        85.84495   73.8539  ]\n"," [ 96.       118.695244  74.59004 ]\n"," [ 97.       105.82802   75.36618 ]\n"," [ 98.        84.461685  74.445076]\n"," [ 99.        78.80712   74.33754 ]]\n","\n","💾 Таблица условной агрегации сохранена в conditional_agg.npy\n"]}]},{"cell_type":"code","source":["# 7.Лаговые признаки и анализ временных сдвигов\n","dt_stage7 = np.dtype(data_stage5.dtype.descr + [\n","    ('vib_lag', 'float32'),      # Предыдущее значение вибрации\n","    ('vib_diff', 'float32')      # Разница (текущее - предыдущее)\n","])\n","data_stage7 = np.zeros(len(data_stage5), dtype=dt_stage7)\n","\n","# Копируем старые данные\n","for name in data_stage5.dtype.names:\n","    data_stage7[name] = data_stage5[name]\n","\n","\n","# 2. Создание лагового признака(np.roll)\n","lagged_values = np.roll(data_stage7['vib'], 1)\n","\n","lagged_values[0] = np.nan\n","\n","# Записываем в новое поле\n","data_stage7['vib_lag'] = lagged_values\n","\n","print(\"Создан признак vib_lag (предыдущее значение).\")\n","\n","# Разница = Текущее значение - Лаговое значение\n","diff_values = data_stage7['vib'] - data_stage7['vib_lag'] # Текущее значение минус предыдущее значение.\n","data_stage7['vib_diff'] = diff_values\n","\n","print(\"Вычислена разница (vib_diff).\")\n","\n","signs = np.sign(diff_values)\n","\n","# Убираем NaN из анализа, так как первый замер не имеет разницы\n","valid_signs = signs[~np.isnan(signs)]\n","\n","# Считаем, сколько раз встретилось каждое значение (-1, 0, 1)\n","unique_signs, counts = np.unique(valid_signs, return_counts=True)\n","\n","total_records = len(valid_signs) # Считаем общее количество записей, которые мы анализируем\n","\n","print(\"\\nРаспределение изменений вибрации:\")\n","for sign, count in zip(unique_signs, counts):\n","    percent = (count / total_records) * 100\n","    if sign == -1.0:\n","        status = \" ПАДАЛО\"\n","    elif sign == 1.0:\n","        status =  \" РОСЛО\"\n","    else:\n","        status = \"НЕ МЕНЯЛОСЬ\"\n","\n","    print(f\"  {status:<15}: {count:>6} записей ({percent:.2f}%)\")\n","\n","np.save('/content/data_stage7.npy', data_stage7)\n","print(\"\\n Массив с лагами сохранен в data_stage7.npy\")"],"metadata":{"colab":{"base_uri":"https://localhost:8080/"},"collapsed":true,"id":"vCajgGAw0fDP","outputId":"1d6c87e5-3cb6-4a4c-d5e6-b0e331126aea"},"execution_count":null,"outputs":[{"output_type":"stream","name":"stdout","text":["Создан признак vib_lag (предыдущее значение).\n","Вычислена разница (vib_diff).\n","\n","Распределение изменений вибрации:\n","   ПАДАЛО        : 152304 записей (49.99%)\n","   РОСЛО         : 152336 записей (50.01%)\n","\n"," Массив с лагами сохранен в data_stage7.npy\n"]}]},{"cell_type":"code","source":["# 8. Групповая робастная замена выбросов\n","data = data_stage7\n","unique_wells = np.unique(data['well_id'])\n","\n","# 1. Создаём массив\n","dt_stage8 = np.dtype(data.dtype.descr + [('vib_iqr_cleaned', 'float32')])\n","data_stage8 = np.zeros(len(data), dtype=dt_stage8)\n","\n","# Копируем все старые данные\n","for name in data.dtype.names:\n","    data_stage8[name] = data[name]\n","\n","# Инициализируем новое поле копией оригинальной вибрации\n","data_stage8['vib_iqr_cleaned'] = data['vib'].copy()\n","\n","total_replaced = 0\n","print(f\"{'ID скважины':<12} | {'Q1':<7} | {'Q3':<7} | {'IQR':<7} | {'Ниж. гр.':<8} | {'Верх. гр.':<8} | {'Заменено'}\")\n","print(\"-\" * 85)\n","\n","# 2. Цикл по группам\n","for well_id in unique_wells:\n","    # выделяем все строки текущей скважины\n","    mask_group = data_stage8['well_id'] == well_id\n","    vib_group = data_stage8['vib'][mask_group]\n","\n","    # 2.1. Находим медиану\n","    Q1 = np.nanpercentile(vib_group, 25) # Находим 25-й процентиль (нижнюю квартиль Q1)\n","    Q3 = np.nanpercentile(vib_group, 75) # Находим 75-й процентиль (верхнюю квартиль Q3).\n","    IQR = Q3 - Q1 # Считаем межквартильный размах\n","    median_group = np.nanmedian(vib_group) # Находим медиану (среднее значение) для этой скважины.\n","\n","    # 2.2. Вычисляем границы выбросов\n","    lower_bound = Q1 - 1.5 * IQR # Нижняя граница нормы.\n","    upper_bound = Q3 + 1.5 * IQR # Верхняя граница нормы.\n","\n","    # 2.3. Ищем выбросы\n","    valid_mask = ~np.isnan(vib_group)\n","    outlier_mask = valid_mask & ((vib_group < lower_bound) | (vib_group > upper_bound))\n","\n","    # 2.4. Заменяем выбросы на медиану групп\n","    cleaned_vib_group = np.where(outlier_mask, median_group, vib_group)\n","\n","    # Записываем очищенный фрагмент обратно в общий массив\n","    data_stage8['vib_iqr_cleaned'][mask_group] = cleaned_vib_group\n","\n","    # Считаем количество замен в этой группе\n","    n_replaced = np.sum(outlier_mask)\n","    total_replaced += n_replaced\n","\n","    # Вывод статистики по группе\n","    print(f\"{well_id:<12} | {Q1:<7.2f} | {Q3:<7.2f} | {IQR:<7.2f} | \"\n","          f\"{lower_bound:<8.2f} | {upper_bound:<8.2f} | {n_replaced}\")\n","\n","# 3. Итоговая статистика\n","replaced_percent = (total_replaced / len(data_stage8)) * 100\n","print(f\"\\n Всего заменено выбросов: {total_replaced} ({replaced_percent:.2f}% от общего числа записей)\")\n","\n","# Сохранение результата\n","np.save('/content/data_stage8.npy', data_stage8)\n","print(\" Массив сохранён в data_stage8.npy\")"],"metadata":{"colab":{"base_uri":"https://localhost:8080/"},"collapsed":true,"id":"3FU5XWBv4iHM","outputId":"2b29a63d-c551-413b-9408-76e7730023ae"},"execution_count":null,"outputs":[{"output_type":"stream","name":"stdout","text":["