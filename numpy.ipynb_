{"nbformat":4,"nbformat_minor":0,"metadata":{"colab":{"provenance":[{"file_id":"https://gist.github.com/riorita41-cloud/c977bfa2d40a87507af4ce7f6af5334b#file-numpy-ipynb","timestamp":1779855894442}],"authorship_tag":"ABX9TyOSUcJPl4OKlO3DwCg5kjVU"},"kernelspec":{"name":"python3","display_name":"Python 3"},"language_info":{"name":"python"}},"cells":[{"cell_type":"code","source":["import numpy as np\n","print(\"NumPy подключен\")"],"metadata":{"id":"vDDvOXpiiB3i","colab":{"base_uri":"https://localhost:8080/"},"outputId":"c9bffbd8-4b29-41e1-ef95-17f6cf714e85","collapsed":true},"execution_count":null,"outputs":[{"output_type":"stream","name":"stdout","text":["NumPy подключен\n"]}]},{"cell_type":"code","source":["# 1.Загрузка и подготовка типов\n","dt = np.dtype([\n","    ('ts', 'int32'),        # время замера - целое число\n","    ('well_id', 'int16'),   # номер скважины - целое число\n","    ('press', 'float32'),   # давление - дробное число\n","    ('temp', 'float32'),    # температура - дробное число\n","    ('vib', 'float32'),     # вибрация - дробное число\n","    ('fluid', 'float32')    # доля нефти - дробное число\n","])\n","\n","# Читаем CSV файл\n","data = np.genfromtxt(\n","'/content/data.csv',\n","    delimiter=',',         # данные разделены запятыми\n","    skip_header=1,         # пропускаем первую строку (заголовки)\n","    dtype=dt,              # используем наши типы\n","    invalid_raise=False    # Игнорировать ошибки при несовпадении числа колонок\n",")\n","\n","# Проверяем что прочиталось\n","print(f\"Количество строк: {len(data)}\")\n","print(f\"Типы данных: {data.dtype}\")\n","print(\"Первые 3 строки:\")\n","print(data[:3])"],"metadata":{"id":"OP8xDb5EiGaq","colab":{"base_uri":"https://localhost:8080/"},"outputId":"c4db006b-dec3-4f79-9067-0e6fec39a23e","collapsed":true},"execution_count":null,"outputs":[{"output_type":"stream","name":"stdout","text":["Количество строк: 151126\n","Типы данных: [('ts', '<i4'), ('well_id', '<i2'), ('press', '<f4'), ('temp', '<f4'), ('vib', '<f4'), ('fluid', '<f4')]\n","Первые 3 строки:\n","[(1600000025, 80, 12.942132, -13.219301, 49.678867, 67.)\n"," (1600000033, 86, 14.384695,  20.832235, 64.96767 , 33.)\n"," (1600000089, 22, 17.536705,  23.94633 , 55.992077, 79.)]\n"]}]},{"cell_type":"code","source":["# Объём памяти\n","bytes_size = data.nbytes\n","mb_size = bytes_size / (1024 * 1024)\n","print(f\"Объём памяти: {bytes_size} байт = {mb_size:.2f} Мбайт\")\n","\n","# Подсчёт NaN и Inf\n","nan_total = 0\n","inf_total = 0\n","\n","for field in ['press', 'temp', 'vib', 'fluid']:\n","    nan_total += np.isnan(data[field]).sum() # проверяем пустые значения\n","    inf_total += np.isinf(data[field]).sum() # проверяем на бесконечность\n","\n","# Всего числовых значений: строки * 4 числовых поля\n","all_values = len(data) * 4 # Считаем общее количество числовых значений.\n","percent = (nan_total + inf_total) / all_values * 100 # Считаем какой процент данных «испорчен».\n","\n","print(f\"NaN значений: {nan_total}\")\n","print(f\"Inf значений: {inf_total}\")\n","print(f\"Доля от всех числовых данных: {percent:.2f}%\")\n","\n","if percent > 3:\n","    print(\"ПРЕДУПРЕЖДЕНИЕ: пропусков больше 3%!\")\n","else:\n","    print(\"Всё в порядке: пропусков меньше 3%\")\n","\n","# --- Сохраняем массив ---\n","np.save('/content/raw_wells.npy', data)\n","print(\"Массив сохранён в файл raw_wells.npy\")"],"metadata":{"id":"aKx3a6-Sjk-k","colab":{"base_uri":"https://localhost:8080/"},"collapsed":true,"outputId":"e32cb7af-69dc-48d4-f167-b44bc0901194"},"execution_count":null,"outputs":[{"output_type":"stream","name":"stdout","text":["Объём памяти: 3324772 байт = 3.17 Мбайт\n","NaN значений: 18082\n","Inf значений: 0\n","Доля от всех числовых данных: 2.99%\n","Всё в порядке: пропусков меньше 3%\n","Массив сохранён в файл raw_wells.npy\n"]}]},{"cell_type":"code","source":["# 2. Векторизованная фильтрация и очистка\n","# Ищем аномалии\n","# 1. Давление отрицательное (не может быть в реальности)\n","mask_press = data['press'] < 0\n","print(f\"Отрицательное давление: {mask_press.sum()} строк ({mask_press.sum()/len(data)*100:.2f}%)\")\n","\n","# 2. Доля нефти больше 100% (невозможно)\n","mask_fluid = data['fluid'] > 100\n","print(f\"Доля нефти > 100%: {mask_fluid.sum()} строк ({mask_fluid.sum()/len(data)*100:.2f}%)\")\n","\n","# 3. NaN в любом числовом поле (пропуски)\n","mask_nan = (np.isnan(data['press']) | np.isnan(data['temp']) |\n","            np.isnan(data['vib'])   | np.isnan(data['fluid']))\n","print(f\"Пропуски (NaN): {mask_nan.sum()} строк ({mask_nan.sum()/len(data)*100:.2f}%)\")\n","\n","# 4. Все аномалии вместе\n","mask_all = mask_press | mask_fluid | mask_nan\n","print(f\"\\nВсего строк с аномалиями: {mask_all.sum()} ({mask_all.sum()/len(data)*100:.2f}%)\")"],"metadata":{"id":"4DyTkUu64k2r","colab":{"base_uri":"https://localhost:8080/"},"collapsed":true,"outputId":"cfcbfd25-844f-46bb-b647-512b228379be"},"execution_count":null,"outputs":[{"output_type":"stream","name":"stdout","text":["Отрицательное давление: 7264 строк (4.81%)\n","Доля нефти > 100%: 4346 строк (2.88%)\n","Пропуски (NaN): 17227 строк (11.40%)\n","\n","Всего строк с аномалиями: 27605 (18.27%)\n"]}]},{"cell_type":"code","source":["# 3.Группировка + Нормализация\n","# 1. Находим уникальные ID скважин\n","unique_wells = np.unique(data['well_id'])\n","n_groups = len(unique_wells)\n","print(f\" Количество групп (скважин): {n_groups}\")\n","\n","# 2. Создаём новый dtype с дополнительным полем для нормализованной вибрации\n","dt_extended = np.dtype(data.dtype.descr + [('vib_norm', 'float32')])\n","data_norm = np.zeros(len(data), dtype=dt_extended)\n","\n","# Копируем все старые данные в новый массив\n","for name in data.dtype.names:\n","    data_norm[name] = data[name]\n","\n","# 3. Цикл  по группам\n","group_stats = []\n","for well_id in unique_wells:\n","    mask = data['well_id'] == well_id\n","\n","    # Мощность группы (сколько строк у этой скважины)\n","    group_size = np.sum(mask)\n","\n","    # Векторизованное извлечение данных группы\n","    vib_group = data['vib'][mask]\n","    press_group = data['press'][mask]\n","\n","    # Расчёт статистики по группе\n","    mean_vib = np.nanmean(vib_group)\n","    std_vib = np.nanstd(vib_group)\n","    max_press = np.nanmax(press_group)\n","\n","    # Сохраняем статистику для отчёта\n","    group_stats.append((well_id, group_size, mean_vib, std_vib, max_press))\n","    print(f\"  Скважина {well_id}: записей={group_size:3d} | ср.vib={mean_vib:6.2f} | макс.press={max_press:6.2f}\")\n","\n","    # Z-score нормализация вибрации\n","    if std_vib > 0:\n","        z_scores = (vib_group - mean_vib) / std_vib\n","    else:\n","        # Если разброс нулевой, все значения одинаковы → z=0\n","        z_scores = np.zeros_like(vib_group)\n","\n","    # Векторизованная запись результата в новый массив по маске\n","    data_norm['vib_norm'][mask] = z_scores\n","\n","print(f\"\\n Нормализация завершена. Проверка: mean(vib_norm) ≈ {np.mean(data_norm['vib_norm']):.4f}, std(vib_norm) ≈ {np.std(data_norm['vib_norm']):.4f}\")\n","\n","# 4. Сохраняем результат\n","np.save('/content/data_stage3.npy', data_norm)\n","print(f\"\\n Нормализация завершена. Проверка: mean(vib_norm) ≈ {np.nanmean(data_norm['vib_norm']):.4f}, std(vib_norm) ≈ {np.nanstd(data_norm['vib_norm']):.4f}\")"],"metadata":{"id":"8S2OG4jr5Xve","colab":{"base_uri":"https://localhost:8080/"},"collapsed":true,"outputId":"e934e2b2-d4fc-46cb-a443-cec4a1c4c2a5"},"execution_count":null,"outputs":[{"output_type":"stream","name":"stdout","text":[" Количество групп (скважин): 100\n","  Скважина 0: записей=1543 | ср.vib= 58.43 | макс.press=180.87\n","  Скважина 1: записей=1523 | ср.vib= 55.91 | макс.press=182.84\n","  Скважина 2: записей=1449 | ср.vib= 55.45 | макс.press=182.83\n","  Скважина 3: записей=1477 | ср.vib= 57.09 | макс.press=178.85\n","  Скважина 4: записей=1520 | ср.vib= 56.40 | макс.press=180.14\n","  Скважина 5: записей=1522 | ср.vib= 55.36 | макс.press=180.52\n","  