         | 32.71   | 69.29   | 36.59   | -22.17   | 124.17   | 190\n","52           | 31.92   | 67.31   | 35.39   | -21.15   | 120.39   | 184\n","53           | 31.64   | 67.54   | 35.91   | -22.23   | 121.40   | 185\n","54           | 31.52   | 68.66   | 37.14   | -24.19   | 124.38   | 165\n","55           | 33.29   | 68.64   | 35.35   | -19.75   | 121.67   | 193\n","56           | 31.24   | 67.48   | 36.25   | -23.14   | 121.86   | 190\n","57           | 30.80   | 66.64   | 35.85   | -22.97   | 120.41   | 174\n","58           | 31.96   | 68.66   | 36.70   | -23.08   | 123.70   | 161\n","59           | 32.16   | 68.26   | 36.10   | -21.99   | 122.41   | 182\n","60           | 32.31   | 67.36   | 35.04   | -20.25   | 119.92   | 177\n","61           | 31.79   | 68.11   | 36.32   | -22.69   | 122.58   | 177\n","62           | 32.96   | 69.39   | 36.43   | -21.68   | 124.03   | 194\n","63           | 31.92   | 67.54   | 35.62   | -21.51   | 120.98   | 195\n","64           | 32.30   | 67.67   | 35.37   | -20.75   | 120.72   | 166\n","65           | 31.95   | 69.18   | 37.23   | -23.89   | 125.02   | 179\n","66           | 31.63   | 68.21   | 36.58   | -23.24   | 123.08   | 158\n","67           | 32.69   | 68.74   | 36.05   | -21.39   | 122.82   | 179\n","68           | 31.41   | 68.64   | 37.23   | -24.44   | 124.49   | 168\n","69           | 31.99   | 67.73   | 35.74   | -21.62   | 121.34   | 182\n","70           | 32.55   | 68.58   | 36.03   | -21.49   | 122.62   | 197\n","71           | 31.22   | 67.39   | 36.17   | -23.04   | 121.64   | 171\n","72           | 31.10   | 68.34   | 37.24   | -24.76   | 124.21   | 169\n","73           | 32.01   | 68.01   | 36.01   | -22.00   | 122.02   | 169\n","74           | 32.82   | 67.69   | 34.87   | -19.48   | 119.99   | 195\n","75           | 32.33   | 68.98   | 36.64   | -22.63   | 123.94   | 169\n","76           | 31.46   | 67.78   | 36.32   | -23.01   | 122.26   | 175\n","77           | 31.55   | 69.05   | 37.50   | -24.71   | 125.31   | 171\n","78           | 32.77   | 68.39   | 35.61   | -20.65   | 121.81   | 181\n","79           | 33.00   | 68.07   | 35.07   | -19.60   | 120.66   | 185\n","80           | 30.79   | 67.30   | 36.51   | -23.98   | 122.06   | 183\n","81           | 32.49   | 67.26   | 34.77   | -19.66   | 119.42   | 177\n","82           | 31.88   | 68.69   | 36.81   | -23.33   | 123.90   | 194\n","83           | 30.65   | 67.88   | 37.23   | -25.19   | 123.73   | 165\n","84           | 30.48   | 67.44   | 36.96   | -24.96   | 122.88   | 169\n","85           | 32.20   | 68.64   | 36.44   | -22.46   | 123.30   | 182\n","86           | 32.47   | 68.22   | 35.75   | -21.16   | 121.85   | 166\n","87           | 32.10   | 67.60   | 35.50   | -21.15   | 120.85   | 172\n","88           | 32.21   | 68.49   | 36.28   | -22.21   | 122.91   | 170\n","89           | 31.62   | 68.20   | 36.58   | -23.25   | 123.08   | 155\n","90           | 32.53   | 67.95   | 35.42   | -20.60   | 121.08   | 157\n","91           | 31.66   | 67.04   | 35.38   | -21.42   | 120.11   | 168\n","92           | 30.63   | 67.12   | 36.49   | -24.10   | 121.86   | 186\n","93           | 31.08   | 66.64   | 35.56   | -22.25   | 119.98   | 165\n","94           | 31.01   | 67.28   | 36.27   | -23.40   | 121.69   | 189\n","95           | 34.00   | 68.88   | 34.88   | -18.33   | 121.20   | 173\n","96           | 31.09   | 67.73   | 36.64   | -23.87   | 122.69   | 179\n","97           | 31.97   | 68.46   | 36.49   | -22.77   | 123.20   | 177\n","98           | 31.56   | 67.63   | 36.06   | -22.53   | 121.72   | 202\n","99           | 31.14   | 68.33   | 37.19   | -24.64   | 124.11   | 182\n","\n"," Всего заменено выбросов: 17791 (5.49% от общего числа записей)\n"," Массив сохранён в data_stage8.npy\n"]}]},{"cell_type":"code","source":["# 9.Проверка согласованности и логической целостности\n","# 1. Предметные правила\n","# Давление не может быть отрицательным\n","mask_press_invalid = data['press'] < 0\n","\n","# Доля нефти не может быть < 0% или > 100%\n","mask_fluid_invalid = (data['fluid'] < 0) | (data['fluid'] > 100)\n","\n","# Вибрация бурения не может быть отрицательной\n","mask_vib_invalid = data['vib'] < 0\n","\n","# Температура породы в продуктивном пласте не может быть отрицательной (°C)\n","mask_temp_invalid = data['temp'] < 0\n","\n","# 2. Состовная маска нарушений\n","# Объединяем все условия через логическое ИЛИ\n","mask_all_invalid = mask_press_invalid | mask_fluid_invalid | mask_vib_invalid | mask_temp_invalid\n","\n","# 3. Статистика нарушений\n","n_invalid = np.sum(mask_all_invalid) # считает количество True (сколько строк содержат ошибки).\n","total_rows = len(data)\n","percent_invalid = (n_invalid / total_rows) * 100 # Доля нарушени в  %\n","\n","print(f\"Результаты проверки согласованности:\")\n","print(f\"   Давление < 0          : {np.sum(mask_press_invalid)} строк\")\n","print(f\"   Доля нефти вне [0,100]: {np.sum(mask_fluid_invalid)} строк\")\n","print(f\"   Вибрация < 0          : {np.sum(mask_vib_invalid)} строк\")\n","print(f\"   Температура < 0       : {np.sum(mask_temp_invalid)} строк\")\n","print(f\"\\n Всего строк с нарушениями: {n_invalid} ({percent_invalid:.2f}%)\")\n","\n","\n","# 4. Исправление через np.where\n","# Заменяем некорректные значения на физические границы\n","data['press'] = np.where(mask_press_invalid, 0.0, data['press'])\n","data['fluid'] = np.where(data['fluid'] < 0, 0.0, data['fluid'])\n","data['fluid'] = np.where(data['fluid'] > 100, 100.0, data['fluid'])\n","data['vib']   = np.where(mask_vib_invalid, 0.0, data['vib'])\n","data['temp']  = np.where(mask_temp_invalid, 0.0, data['temp'])\n","\n","print(\"\\n Некорректные значения заменены на  физические границы.\")\n","\n","np.save('/content/data_stage9.npy', data)\n","print(\" Массив сохранён в data_stage9.npy\")"],"metadata":{"colab":{"base_uri":"https://localhost:8080/"},"collapsed":true,"id":"utgIlUwj75Mp","outputId":"5437eb68-38ee-4dd9-efb1-d9752fa22e01"},"execution_count":null,"outputs":[{"output_type":"stream","name":"stdout","text":["Результаты проверки согласованности:\n","   Давление < 0          : 15808 строк\n","   Доля нефти вне [0,100]: 18537 строк\n","   Вибрация < 0          : 9181 строк\n","   Температура < 0       : 15830 строк\n","\n"," Всего строк с нарушениями: 55420 (17.12%)\n","\n"," Некорректные значения заменены на  физические границы.\n"," Массив сохранён в data_stage9.npy\n"]}]},{"cell_type":"code","source":["# 10.Частотный анализ и сжатие редких категорий\n","data = np.load('/content/data_stage9.npy', allow_pickle=True)\n","total_rows = len(data)\n","\n","# 1. Частотный анализ\n","unique_ids, counts = np.unique(data['well_id'], return_counts=True)\n","print(f\" Всего уникальных скважин: {len(unique_ids)}\")\n","\n","# 2. ПОРОГ 1%\n","threshold = total_rows * 0.01 # Вычисляет число, равное 1% от общего объёма данных\n","print(f\" Порог редкости (1%): {threshold:.0f} записей\")\n","\n","# Находим скважины, встречающиеся реже порога\n","rare_mask = counts < threshold\n","rare_ids = unique_ids[rare_mask]\n","\n","print(f\"\\n Найдено редких скважин (< 1%): {len(rare_ids)}\")\n","if len(rare_ids) > 0:\n","    print(f\"   Их ID: {rare_ids}\")\n","else:\n","    print(\"    Редких категорий не обнаружено (все скважины распределены равномерно).\")\n","\n","# 3. СОЗДАНИЕ НОВОГО ПОЛЯ И СЖАТИЕ\n","dt_final = np.dtype(data.dtype.descr + [('well_id_compressed', 'int16')])\n","data_final = np.zeros(total_rows, dtype=dt_final) # Выделяет память под новый массив нужной длины и новой структуры.\n","\n","for name in data.dtype.names:\n","    data_final[name] = data[name]\n","\n","data_final['well_id_compressed'] = data['well_id'].copy()\n","OTHER_CODE = 255  # Код для категории OTHER\n","\n","if len(rare_ids) > 0:\n","    mask_rare = np.isin(data_final['well_id_compressed'], rare_ids)\n","    data_final['well_id_compressed'] = np.where(mask_rare, OTHER_CODE, data_final['well_id_compressed'])\n","    n_replaced = np.sum(mask_rare)\n","    print(f\"\\n Редкие категории объединены в OTHER (код {OTHER_CODE})\")\n","    print(f\"   Перенесено записей: {n_replaced} ({n_replaced / total_rows * 100:.2f}%)\")\n","else:\n","    print(\"\\n Все категории достаточно частые. Сжатие не потребовалось.\")\n","\n","# 4. Финальное распределение категорий\n","print(\"\\n\" + \"=\"*60)\n","print(\"Финальное распределение категорий:\")\n","final_ids, final_counts = np.unique(data_final['well_id_compressed'], return_counts=True)\n","\n","for uid, cnt in zip(final_ids, final_counts):\n","    label = f\"OTHER (код {uid})\" if uid == OTHER_CODE else f\"Скважина {uid}\"\n","    print(f\"  {label:<20}: {cnt:>6} записей ({cnt / total_rows * 100:.2f}%)\")\n","print(\"=\"*60)\n","\n","# 5. СОХРАНЕНИЕ\n","np.save('/content/data_final.npy', data_final)\n","print(\" Итоговый массив сохранён в data_final.npy\")"],"metadata":{"colab":{"base_uri":"https://localhost:8080/"},"id":"o3xhliq3_GtD","outputId":"43b4ba28-c6e6-47bc-ac44-10d682175ad5","collapsed":true},"execution_count":null,"outputs":[{"output_type":"stream","name":"stdout","text":[" Всего уникальных скважин: 100\n"," Порог редкости (1%): 3238 записей\n","\n"," Найдено редких скважин (< 1%): 56\n","   Их ID: [ 0  1  2  5  6  8 11 13 14 19 20 21 22 23 24 25 28 31 32 34 36 41 43 44\n"," 45 46 48 49 50 53 60 61 63 64 65 66 68 71 73 74 75 78 79 81 83 84 85 88\n"," 89 91 93 94 95 96 97 98]\n","\n"," Редкие категории объединены в OTHER (код 255)\n","   Перенесено записей: 178957 (55.27%)\n","\n","============================================================\n","Финальное распределение категорий:\n","  Скважина 3          :   3252 записей (1.00%)\n","  Скважина 4          :   3298 записей (1.02%)\n","  Скважина 7          :   3305 записей (1.02%)\n","  Скважина 9          :   3241 записей (1.00%)\n","  Скважина 10         :   3262 записей (1.01%)\n","  Скважина 12         :   3320 записей (1.03%)\n","  Скважина 15         :   3270 записей (1.01%)\n","  Скважина 16         :   3